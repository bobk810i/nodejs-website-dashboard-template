<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.8/dist/umd/popper.min.js" integrity="sha384-I7E8VVD/ismYTF4hNIPjVp/Zjvgyol6VFvRkX/vR+Vc4jQkC+hVqc2pM8ODewa9r" crossorigin="anonymous"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js" integrity="sha512-v2CJ7UaYy4JwqLDIrZUI/4hqeoQieOmAZNXBeQyjo21dadnwR+8ZaIJVT8EE2iyI61OV8e6M8PP2/4hpQINQ/g==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="/style/style.css">

    <title>Dashboard | Login</title>
    <link rel="icon" type="image/x-icon" href="/graphics/favicon.ico">
</head>
<body class="font-sans" style="overflow-x: hidden; background-color:#FAFAFA;">
    <main class="w-100 d-flex justify-content-center mt-5 pt-5">
        <div class="card mt-5" style="width: 20%;">
            <div class="card-body">
              <!-- <h5 class="card-title">Logowanie</h5> -->
              <form action="/dashboard/login" method="POST">
                <p class="card-text mb-2">Login</p>
                <input type="text" name="username" id="login-input" class="form-control w-100 mb-2">
                <p class="card-text mb-2">Hasło</p>
                <input type="password" name="password" id="password-input" class="form-control w-100 mb-3">
                <button class="btn btn-outline-success w-100" type="submit">Zaloguj</button>
              </form>
            </div>
          </div>
    </main>
</body>
</html>